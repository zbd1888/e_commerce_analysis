root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json,js,vue,java,py,xml,css,html}]
indent_style = space
indent_size = 2

[*.java]
indent_size = 4

[*.py]
indent_size = 4

[*.bat]
charset = gbk
trim_trailing_whitespace = false

